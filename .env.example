# Core site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Public image bucket/base URL
NEXT_PUBLIC_BUCKET_URL=https://s3.cunyli.top

# Admin access
ADMIN_EMAILS=admin@example.com
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com

# Cloudflare R2 / S3-compatible uploads
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# OpenAI or Azure OpenAI for image analysis and translation
OPENAI_API_KEY=your-openai-api-key
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=

# Semantic picture search and image embeddings
SEMANTIC_EMBEDDING_PROVIDER=jina
JINA_API_KEY=your-jina-api-key
JINA_EMBEDDING_MODEL=jina-embeddings-v5-omni-small
JINA_EMBEDDING_DIMENSIONS=1024
TEXT_EMBEDDING_API_URL=
TEXT_EMBEDDING_API_KEY=
IMAGE_EMBEDDING_API_URL=
IMAGE_EMBEDDING_API_KEY=
HF_IMAGE_EMBEDDING_API_URL=
HF_IMAGE_EMBEDDING_API_KEY=
HF_TOKEN=
HUGGINGFACEHUB_API_TOKEN=

# Optional embedding job tuning
PICTURE_EMBEDDING_BATCH_SIZE=1
PICTURE_EMBEDDING_CONCURRENCY=2
PICTURE_JOB_CONCURRENCY=4
